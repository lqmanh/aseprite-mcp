ASEPRITE_PATH=/path/to/aseprite

# Base directory for relative paths
# Optional, but RECOMMENDED to set to your project root
# If not set, the current working directory is used, aka this aseprite-mcp repository
ASEPRITE_WORKDIR=/path/to/your/project

# --- Optional: Install Aseprite from Steam ---
# Provide these to enable runtime install using SteamCMD.
# WARNING: Do not commit credentials; prefer using environment variables or secrets.
# STEAM_USERNAME=your_steam_username
# STEAM_PASSWORD=your_steam_password
# If Steam Guard is enabled:
# STEAM_GUARD_CODE=XXXXX
# Optional overrides:
# STEAM_APPID=431730
# STEAM_INSTALL_DIR=/opt/steamapps
